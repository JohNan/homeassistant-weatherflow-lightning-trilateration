{
  "name": "weatherflow-lightning-trilateration",
  "version": "1.0.0",
  "description": "Lovelace card build tooling",
  "type": "module",
  "scripts": {
    "lint": "eslint src/**/*.js",
    "format:check": "prettier --check src/**/*.js",
    "format": "prettier --write src/**/*.js",
    "build": "esbuild src/weatherflow-lightning-card.js --minify --outfile=custom_components/weatherflow_lightning_trilateration/dist/weatherflow-lightning-card.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.5.0",
    "esbuild": "^0.21.5",
    "eslint": "^9.5.0",
    "globals": "^17.7.0",
    "prettier": "^3.8.4"
  }
}
